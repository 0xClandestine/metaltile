#!/usr/bin/env bash
#
# commit-msg — runs the same hygiene regex CI uses, against the local
# commit message BEFORE the commit lands. Mirrors the rules in
# .github/scripts/commit_hygiene.py:
#
#   1. Reject AI-tool / LLM model names anywhere in the message
#      (claude, anthropic, codex, openai, chatgpt, gpt-N, antigravity,
#       gemini, bard, copilot, cursor, sourcegraph, cody, devin, aider,
#       windsurf, tabnine, llama, mistral, grok, perplexity, replit,
#       ghostwriter, pieces). Word-boundary case-insensitive.
#
#   2. Reject Git-trailer-shaped lines (^Word: ) in the trailing
#      paragraph after a blank line — Co-Authored-By + friends.
#      The CI also matches plain `Tests:` / `Tolerance:` style summary
#      lines, so phrase those as `Test results —` / `Tolerance —` in
#      the message body.
#
# Bypass with `git commit --no-verify` if you know what you're doing.

set -e

MSG_FILE="$1"
[ -z "$MSG_FILE" ] && exit 0

# Strip comment lines (`#` is the comment prefix in Git commit messages).
BODY="$(grep -v '^#' "$MSG_FILE" || true)"

# ─── 1. Banned-term scan ─────────────────────────────────────────────
BANNED_REGEX='\b(claude|anthropic|codex|openai|chatgpt|gpt[- ]?[0-9]|antigravity|gemini|bard|copilot|cursor|sourcegraph|cody|devin|aider|windsurf|tabnine|llama|mistral|grok|perplexity|replit|ghostwriter|pieces)\b'

if echo "$BODY" | grep -iE "$BANNED_REGEX" >/dev/null; then
    echo "✗ commit-msg: banned AI/LLM term in commit message"
    echo
    echo "  Matched lines:"
    echo "$BODY" | grep -iEn "$BANNED_REGEX" | head -5 | sed 's/^/    /'
    echo
    echo "  Strip the term or rephrase. Bypass with --no-verify."
    exit 1
fi

# ─── 2. Trailer-shaped tail scan ─────────────────────────────────────
# Walk lines from the bottom up; if the trailing block (separated from
# the body by a blank line) contains any `Word:\s` lines, those CI
# treats as trailers — fail the commit.

TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT
echo "$BODY" > "$TMP"

# Strip trailing blank lines so we look at real content first.
sed -i.bak -e :a -e '/^[[:space:]]*$/{$d;N;ba' -e '}' "$TMP" 2>/dev/null || true

# Walk backward — collect consecutive trailer-shaped lines until a
# blank line OR a non-trailer line.
trailers_in_tail=0
in_tail_block=1
total_lines=$(wc -l < "$TMP")
for i in $(seq "$total_lines" -1 1); do
    line=$(sed -n "${i}p" "$TMP")
    if [ -z "${line// }" ]; then
        # Blank line — stop walking up. If we were in the tail block
        # and saw trailer-shaped lines, that's the "trailer paragraph"
        # CI rejects.
        break
    fi
    if [ "$in_tail_block" = "1" ] && echo "$line" | grep -E '^[A-Za-z][A-Za-z0-9-]*:[[:space:]]' >/dev/null; then
        trailers_in_tail=$((trailers_in_tail + 1))
    else
        # Not trailer-shaped — we're past the trailer block.
        in_tail_block=0
    fi
done

if [ "$trailers_in_tail" -gt 0 ]; then
    echo "✗ commit-msg: $trailers_in_tail Git-trailer-shaped line(s) in trailing paragraph"
    echo
    echo "  CI's hygiene check treats trailing 'Word:\s...' lines as Co-Authored-By-"
    echo "  style trailers and rejects them. Common false-positive offenders:"
    echo "    - 'Tests: 7/7 pass' → use 'Test results — 7/7 pass'"
    echo "    - 'Tolerance: 1e-5' → use 'Tolerance — 1e-5'"
    echo "    - 'Shape: …'        → use 'Shape — …'"
    echo
    echo "  Either rephrase or move them mid-body before the closing paragraph."
    echo "  Bypass with --no-verify."
    exit 1
fi

exit 0
